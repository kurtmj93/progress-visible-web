---
// System-following theme toggle. Persists an explicit choice to localStorage; clearing
// back to "system" is out of scope for v1 (a saved choice simply wins).
---
<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle light or dark theme"
  class="grid h-9 w-9 place-items-center rounded-md text-ink-soft transition-colors hover:bg-paper-raised hover:text-ink"
>
  <!-- sun (shown in dark, click → light) -->
  <svg class="hidden h-5 w-5 dark-only" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
    <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <!-- moon (shown in light, click → dark) -->
  <svg class="h-5 w-5 light-only" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  </svg>
</button>

<style>
  /* Show the correct icon for the active theme (system + explicit override). */
  .dark-only { display: none; }
  .light-only { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .dark-only { display: block; }
    :root:not([data-theme="light"]) .light-only { display: none; }
  }
  :root[data-theme="dark"] .dark-only { display: block; }
  :root[data-theme="dark"] .light-only { display: none; }
  :root[data-theme="light"] .dark-only { display: none; }
  :root[data-theme="light"] .light-only { display: block; }
</style>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const explicit = root.getAttribute('data-theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const current = explicit || (systemDark ? 'dark' : 'light');
      const next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>
