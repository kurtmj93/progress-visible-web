---
import { SITE } from '../consts';
interface Props {
  /** Show the PV icon plus the studio name, or just the icon. */
  showText?: boolean;
  class?: string;
}
const { showText = false, class: cls = 'h-8 w-auto' } = Astro.props;
---
<a href="/" class="group inline-flex items-center gap-2.5 text-ink" aria-label={SITE.name}>
  <!-- PV icon (public/pv-icon.svg), inlined so it adapts to the theme:
       the letter shapes inherit currentColor (black ↔ white); the tick stays brand green. -->
  <svg class={cls} viewBox="0 0 71.95 76.89" fill="currentColor" role="img" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path fill="var(--color-accent)" d="M23.35,76.89L4.99,28.42h19.65l4.68,15.7c.3.86.69,2.14,1.15,3.86.46,1.71.98,3.52,1.56,5.42.58,1.9,1.09,3.64,1.51,5.23h.64c.43-1.47.92-3.14,1.47-5,.55-1.87,1.07-3.66,1.56-5.37.49-1.71.89-3.09,1.19-4.13L51.56,0l20.38.02-29.41,76.87h-19.19Z"/>
    <path d="M0,76.89V10.33h14.87l1.56,6.89h.64c1.71-2.88,3.82-4.93,6.33-6.15,2.51-1.22,5.32-1.84,8.45-1.84,4.28,0,7.96.93,11.02,2.8,3.06,1.87,5.4,4.68,7.02,8.45,1.62,3.76,2.43,8.49,2.43,14.18s-.81,10.31-2.43,14.05c-1.62,3.73-3.96,6.54-7.02,8.4-3.06,1.87-6.73,2.8-11.02,2.8-1.71,0-3.38-.18-5-.55-1.62-.37-3.11-.96-4.45-1.79-1.35-.83-2.51-1.88-3.49-3.17h-.64v22.49H0ZM26.17,46.41c1.9,0,3.43-.4,4.59-1.19,1.16-.79,2-1.9,2.52-3.31.52-1.41.78-3.06.78-4.96v-4.87c0-1.9-.26-3.55-.78-4.96-.52-1.41-1.36-2.49-2.52-3.26-1.16-.76-2.69-1.15-4.59-1.15s-3.44.46-4.64,1.38-2.07,2.16-2.62,3.72-.83,3.29-.83,5.19v3.03c0,1.41.15,2.74.46,3.99.31,1.25.78,2.36,1.42,3.3.64.95,1.48,1.7,2.52,2.25,1.04.55,2.26.83,3.67.83Z"/>
  </svg>
  {showText && (
    <span class="display text-lg">{SITE.name}</span>
  )}
</a>
