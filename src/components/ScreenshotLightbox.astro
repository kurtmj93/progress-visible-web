---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  light: ImageMetadata;
  dark: ImageMetadata;
  alt: string;
}

const { light, dark, alt } = Astro.props;
const preview = {
  alt,
  widths: [480, 640, 960, 1280],
  sizes: '(max-width: 639px) 100vw, 450px',
  loading: 'lazy' as const,
  decoding: 'async' as const,
  quality: 82,
};
const full = { alt, loading: 'lazy' as const, decoding: 'async' as const, quality: 92 };
---

<figure data-screenshot-lightbox>
  <button
    type="button"
    class="screenshot-trigger group relative block w-full cursor-zoom-in overflow-hidden text-left"
    aria-label={`View full-size screenshot: ${alt}`}
  >
    <Image src={light} {...preview} class="shot-light h-auto w-full transition-transform duration-300 group-hover:scale-[1.01]" />
    <Image src={dark} {...preview} class="shot-dark h-auto w-full transition-transform duration-300 group-hover:scale-[1.01]" />
    <span class="zoom-hint absolute right-3 bottom-3 rounded-sm border border-white/20 bg-black/70 px-2.5 py-1.5 text-xs font-semibold text-white opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100">
      View full size
    </span>
  </button>

  <dialog class="screenshot-dialog m-0 h-full max-h-none w-full max-w-none bg-transparent p-0 text-ink">
    <div class="lightbox-shell">
      <div class="lightbox-toolbar">
        <p class="min-w-0 truncate text-sm text-ink-soft">{alt}</p>
        <div class="flex shrink-0 items-center gap-2">
          <button type="button" class="lightbox-zoom rounded-md border rule bg-paper-raised px-3 py-2 text-xs font-semibold text-ink transition-colors hover:bg-paper" aria-pressed="false">
            100%
          </button>
          <button type="button" class="lightbox-close grid h-9 w-9 place-items-center rounded-md border rule bg-paper-raised text-xl leading-none text-ink transition-colors hover:bg-paper" aria-label="Close full-size screenshot">
            <span aria-hidden="true">×</span>
          </button>
        </div>
      </div>
      <div class="lightbox-viewport">
        <div class="lightbox-canvas">
          <Image src={light} {...full} class="lightbox-image shot-light h-auto w-auto" />
          <Image src={dark} {...full} class="lightbox-image shot-dark h-auto w-auto" />
        </div>
      </div>
    </div>
  </dialog>
</figure>

<style>
  .screenshot-trigger:focus-visible { outline: 3px solid var(--accent); outline-offset: -3px; }
  .screenshot-dialog { color-scheme: light dark; }
  .screenshot-dialog::backdrop { background: rgb(0 0 0 / 0.82); backdrop-filter: blur(6px); }
  .lightbox-shell { display: grid; grid-template-rows: auto 1fr; height: 100dvh; background: color-mix(in srgb, var(--paper) 94%, transparent); }
  .lightbox-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1rem; border-bottom: 1px solid var(--line); background: var(--paper); }
  .lightbox-viewport { min-height: 0; overflow: auto; overscroll-behavior: contain; }
  .lightbox-canvas { display: grid; min-width: 100%; min-height: 100%; place-items: center; padding: clamp(1rem, 3vw, 2.5rem); }
  .lightbox-image { max-width: min(100%, 96rem); max-height: calc(100dvh - 7rem); border: 1px solid var(--line); border-radius: 0.375rem; box-shadow: 0 24px 80px rgb(0 0 0 / 0.35); cursor: zoom-in; }
  .lightbox-viewport.is-actual .lightbox-canvas { width: max-content; height: max-content; }
  .lightbox-viewport.is-actual .lightbox-image { max-width: none; max-height: none; cursor: zoom-out; }
  .shot-dark { display: none; }
  .shot-light { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .shot-dark { display: block; }
    :root:not([data-theme="light"]) .shot-light { display: none; }
  }
  :root[data-theme="dark"] .shot-dark { display: block; }
  :root[data-theme="dark"] .shot-light { display: none; }
  :root[data-theme="light"] .shot-dark { display: none; }
  :root[data-theme="light"] .shot-light { display: block; }
  @media (hover: none) { .zoom-hint { opacity: 1; } }
</style>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-screenshot-lightbox]:not([data-lightbox-ready])').forEach((figure) => {
      figure.setAttribute('data-lightbox-ready', '');
      const trigger = figure.querySelector('.screenshot-trigger');
      const dialog = figure.querySelector('.screenshot-dialog');
      const closeButton = figure.querySelector('.lightbox-close');
      const zoomButton = figure.querySelector('.lightbox-zoom');
      const viewport = figure.querySelector('.lightbox-viewport');
      const images = figure.querySelectorAll('.lightbox-image');
      if (!(trigger instanceof HTMLButtonElement) || !(dialog instanceof HTMLDialogElement) || !(closeButton instanceof HTMLButtonElement) || !(zoomButton instanceof HTMLButtonElement) || !(viewport instanceof HTMLElement)) return;

      const setActualSize = (actual) => {
        viewport.classList.toggle('is-actual', actual);
        zoomButton.setAttribute('aria-pressed', String(actual));
        zoomButton.textContent = actual ? 'Fit' : '100%';
        if (!actual) viewport.scrollTo({ top: 0, left: 0 });
      };
      const close = () => { if (dialog.open) dialog.close(); };
      trigger.addEventListener('click', () => {
        setActualSize(false);
        dialog.showModal();
        document.documentElement.style.overflow = 'hidden';
      });
      closeButton.addEventListener('click', close);
      zoomButton.addEventListener('click', () => setActualSize(!viewport.classList.contains('is-actual')));
      images.forEach((image) => image.addEventListener('click', (event) => {
        event.stopPropagation();
        setActualSize(!viewport.classList.contains('is-actual'));
      }));
      viewport.addEventListener('click', (event) => {
        const target = event.target;
        if (target === viewport || (target instanceof HTMLElement && target.classList.contains('lightbox-canvas'))) close();
      });
      dialog.addEventListener('click', (event) => { if (event.target === dialog) close(); });
      dialog.addEventListener('close', () => {
        document.documentElement.style.overflow = '';
        setActualSize(false);
        trigger.focus();
      });
    });
  })();
</script>
