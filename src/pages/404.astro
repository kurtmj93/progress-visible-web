---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Progress Visible Studio" description="The requested page could not be found.">
  <section class="mx-auto max-w-5xl px-5 py-24 sm:py-32">
    <p class="editorial-kicker mb-4">404</p>
    <h1 class="display text-4xl sm:text-5xl">That page isn't here.</h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-soft">
      The address may have changed, or the page may no longer exist.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-1.5 rounded-lg bg-ink px-5 py-2.5 text-sm font-semibold text-paper transition-opacity hover:opacity-90"
    >
      Return home <span aria-hidden="true">→</span>
    </a>
  </section>
</Base>
