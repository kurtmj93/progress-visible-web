---
import Base from '../layouts/Base.astro';
import { SITE, PRODUCTS } from '../consts';
---
<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-20 pb-16 sm:pt-28 sm:pb-20">
    <p class="editorial-kicker mb-5">A software studio</p>
    <h1 class="max-w-3xl font-serif text-5xl font-semibold leading-[1.05] tracking-tight sm:text-6xl">
      Make progress<br />visible.
    </h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
      {SITE.name} builds calm, buy-once desktop tools for people doing long, patient work —
      software that shows the shape of what you've done instead of hiding it behind busywork.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href="#work"
        class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-accent-ink transition-opacity hover:opacity-90"
      >
        See what we're building
      </a>
      <a
        href="#studio"
        class="rounded-lg px-5 py-2.5 text-sm font-semibold text-ink-soft transition-colors hover:text-ink"
      >
        About the studio →
      </a>
    </div>
  </section>

  <!-- Studio thesis -->
  <section id="studio" class="border-t rule">
    <div class="mx-auto grid max-w-5xl gap-10 px-5 py-16 sm:grid-cols-3 sm:py-20">
      <div class="sm:col-span-1">
        <h2 class="font-serif text-2xl font-semibold tracking-tight">The thesis</h2>
      </div>
      <div class="space-y-4 text-ink-soft sm:col-span-2">
        <p class="text-lg leading-relaxed text-ink">
          Most tools measure activity. We'd rather make <em>progress</em> legible — the quiet,
          accumulating kind that a dashboard of streaks and notifications can't see.
        </p>
        <p class="leading-relaxed">
          That leads to a particular kind of software: local-first, so your work is yours and
          stays on your machine. Buy-once, so we answer to you and not to a churn metric.
          Quiet by default, so the tool gets out of the way and the work stays in view.
        </p>
      </div>
    </div>
  </section>

  <!-- Work / products -->
  <section id="work" class="border-t rule">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
      <div class="mb-10 flex items-baseline justify-between">
        <h2 class="font-serif text-2xl font-semibold tracking-tight">Work</h2>
        <span class="marginalia">Currently</span>
      </div>
      <ul class="space-y-4">
        {PRODUCTS.map((product) => (
          <li>
            <a
              href={product.href}
              class="group block rounded-2xl border rule bg-paper-raised p-6 transition-colors hover:border-accent/40 sm:p-8"
            >
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="font-serif text-xl font-semibold tracking-tight">{product.name}</h3>
                <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-accent">
                  {product.status}
                </span>
              </div>
              <p class="mt-3 max-w-2xl leading-relaxed text-ink-soft">{product.blurb}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent">
                {product.href.replace('https://', '')}
                <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="border-t rule">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
      <h2 class="font-serif text-2xl font-semibold tracking-tight">Say hello</h2>
      <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">
        Questions, press, or partnerships — reach the studio directly.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="mt-6 inline-block font-serif text-2xl font-medium text-accent underline decoration-accent/30 underline-offset-4 transition-colors hover:decoration-accent"
      >
        {SITE.email}
      </a>
    </div>
  </section>
</Base>
