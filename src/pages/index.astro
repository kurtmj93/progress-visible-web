---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Lockup from '../components/Lockup.astro';
import { SITE, PRODUCTS } from '../consts';
import storyboardLight from '../assets/screenshots/storyboard-light.png';
import storyboardDark from '../assets/screenshots/storyboard-dark.png';

// Optional preview shot per product, keyed by name. Both theme variants ship and are
// swapped in CSS (.shot-light / .shot-dark) so the toggle is respected with zero JS.
const SHOTS: Record<string, { light: ImageMetadata; dark: ImageMetadata; alt: string }> = {
  Discbound: {
    light: storyboardLight,
    dark: storyboardDark,
    alt: 'Discbound storyboard — a chapter timeline with word counts, statuses, and note cards',
  },
};
const shotImg = { widths: [480, 720, 960, 1282], sizes: '(max-width: 768px) 100vw, 900px', quality: 82 };
---
<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-20 pb-16 sm:pt-28 sm:pb-20">
    <p class="editorial-kicker ml-1 mb-4">Software & design</p>
    <h1 class="max-w-xl ml-1">
      <Lockup class="h-auto w-full max-w-lg" />
      <span class="sr-only">{SITE.name}</span>
    </h1>
    <p class="display max-w-2xl text-4xl sm:text-5xl">
      is making progress <span class="text-accent">visible</span>.
    </p>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
      {SITE.name} builds budget-conscious websites and software—old-fashioned buy once, own forever tools that make complex work possible and meaningful progress visible. Tools that <u>don't</u> lock progress and growth behind a monthly subscription, and <u>don't</u> ask you to pay for services you don't need. Everything you need to advance the work that matters. Nothing you don't.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href="#work"
        class="rounded-lg bg-ink px-5 py-2.5 text-sm font-semibold text-paper transition-opacity hover:opacity-90"
      >
        See what we're building
      </a>
      <a
        href="#studio"
        class="group inline-flex items-center gap-1.5 rounded-lg px-4 py-2.5 text-sm font-semibold text-ink-soft transition-colors hover:text-ink"
      >
        About the studio
        <span class="text-accent transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>
  </section>

  <!-- Studio thesis -->
  <section id="studio" class="border-t rule">
    <div class="mx-auto grid max-w-5xl gap-10 px-5 py-16 sm:grid-cols-3 sm:py-20">
      <div class="sm:col-span-1">
        <h2 class="display text-2xl">On Process</h2>
      </div>
      <div class="space-y-4 text-ink-soft sm:col-span-2">
        <p class="text-lg leading-relaxed text-ink">
          We're <span class="text-accent">Agile</span>, but your tools won't change underneath you.
        </p>
        <p class="leading-relaxed">
          Agile development loops make progress visible and improve the immediacy of feedback loops—we like that. But rapid change for the sake of change <u>isn't</u> meaningful progress. We like Agile development, coupled with old-fashioned testing and delivery. Your software tools are frozen in time—we don't force updates on you. You get updates to manually install—with clear update notes—and maintain access to past versions.
        </p>
      </div>
    </div>
  </section>

  <section id="AI" class="border-t rule">
    <div class="mx-auto grid max-w-5xl gap-10 px-5 py-16 sm:grid-cols-3 sm:py-20">
      <div class="sm:col-span-1">
        <h2 class="display text-2xl">On AI</h2>
      </div>
      <div class="space-y-4 text-ink-soft sm:col-span-2">
        <p class="text-lg leading-relaxed text-ink">
          We're not anti-AI, but we'll be quick to tell you when it's not what you need.
        </p>
        <p class="leading-relaxed">
          The hype around AI is warranted for some use cases, but the one-size-fits-all "brute-force" nature of AI is <em>too expensive</em> for what you actually need—a custom automation, or a considerate and elegant tool. In a world full of AI-enabled tools that can do everything, we make the latter—elegant tools that do <em>what you need them to</em> beautifully and minimally. And when you <em>do</em> need AI for what you want accomplished, we'll let you know how to facilitate that in the most cost-effective way.
        </p>
      </div>
    </div>
  </section>

  <!-- Work / products -->
  <section id="work" class="border-t rule">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
      <div class="mb-10 flex items-baseline justify-between">
        <h2 class="display text-2xl">Work</h2>
        <span class="marginalia">Currently</span>
      </div>
      <ul class="space-y-4">
        {PRODUCTS.map((product) => {
          const shot = SHOTS[product.name];
          return (
          <li>
            <a
              href={product.href}
              class="group block overflow-hidden rounded-2xl border rule bg-paper-raised transition-colors hover:border-accent"
            >
              {shot && (
                <div class="border-b rule bg-paper">
                  <Image src={shot.light} alt={shot.alt} {...shotImg} class="shot-light block h-auto w-full" />
                  <Image src={shot.dark} alt={shot.alt} {...shotImg} class="shot-dark h-auto w-full" />
                </div>
              )}
              <div class="p-6 sm:p-8">
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="display text-xl">{product.name}</h3>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-ink-mute">
                    <span class="h-2 w-2 rounded-full bg-accent"></span>
                    {product.status}
                  </span>
                </div>
                <p class="mt-3 max-w-2xl leading-relaxed text-ink-soft">{product.blurb}</p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent">
                  {product.href.replace('https://', '')}
                  <span class="transition-transform group-hover:translate-x-0.5">→</span>
                </span>
              </div>
            </a>
          </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="border-t rule">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
      <h2 class="display text-2xl">Say hello</h2>
      <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">
        Questions, press, or partnerships — reach the studio directly.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="mt-6 inline-block text-2xl font-semibold text-accent underline decoration-accent/30 underline-offset-4 transition-colors hover:decoration-accent"
      >
        {SITE.email}
      </a>
    </div>
  </section>
</Base>
