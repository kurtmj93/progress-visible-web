# Copy to .env and fill in before running `npm run deploy`.
# .env is gitignored — never commit real values.

# Target S3 bucket (name only, no s3:// prefix).
PV_S3_BUCKET=progressvisible-com

# CloudFront distribution that fronts the bucket.
PV_CLOUDFRONT_DISTRIBUTION_ID=

# AWS region + profile (optional; falls back to your default AWS config).
AWS_REGION=us-east-1
AWS_PROFILE=default
